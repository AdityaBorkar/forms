{
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "taze": "^19.14.1",
    "typescript": "^7.0.1-rc"
  },
  "scripts": {
    "check:lint": "bun biome check --fix .",
    "check:types": "bun tsc -b",
    "prepare": "husky",
    "update:deps": "bun taze -rw --maturity-period 3 && bun install"
  },
  "workspaces": ["./examples", "./www"]
}
