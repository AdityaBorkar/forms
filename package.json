{
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "taze": "^19.14.1",
    "typescript": "^7.0.1-rc"
  },
  "scripts": {
    "analyze:packages": "bun audit",
    "check:lint": "bun biome check --fix .",
    "check:types": "bun tsc -b",
    "prepare": "husky",
    "update:deps": "bun taze -rw --maturity-period 3 && bun install"
  },
  "workspaces": ["./package", "./examples", "./www"]
}
